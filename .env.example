# ============================================================
# Enterprise RAG Knowledge Assistant — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# -----------------------------------------------------------
# GENERAL
# -----------------------------------------------------------
ENVIRONMENT=development  # development | staging | production
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-64-char-secret-key

# -----------------------------------------------------------
# DATABASE — PostgreSQL
# -----------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag_assistant
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql+asyncpg://rag_user:change-me-postgres-password@localhost:5432/rag_assistant

# -----------------------------------------------------------
# REDIS
# -----------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@localhost:6379/0

# -----------------------------------------------------------
# RABBITMQ
# -----------------------------------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=change-me-rabbitmq-password
RABBITMQ_URL=amqp://admin:change-me-rabbitmq-password@localhost:5672/

# -----------------------------------------------------------
# STORAGE — MinIO (dev) / AWS S3 (prod)
# -----------------------------------------------------------
STORAGE_BACKEND=minio  # minio | s3

# MinIO (Development)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-minio-secret
MINIO_BUCKET=rag-documents
MINIO_SECURE=false

# AWS S3 (Production)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET=your-org-rag-documents

# -----------------------------------------------------------
# AUTHENTICATION — Keycloak
# -----------------------------------------------------------
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=rag-enterprise
KEYCLOAK_CLIENT_ID=rag-backend
KEYCLOAK_CLIENT_SECRET=change-me-keycloak-client-secret
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin-password

# JWT Config
JWT_SECRET_KEY=change-me-jwt-secret-key-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------
# LLM PROVIDERS
# -----------------------------------------------------------
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ORG_ID=org-your-openai-org-id
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# Default provider: openai | anthropic | azure | ollama
DEFAULT_LLM_PROVIDER=openai
DEFAULT_EMBEDDING_PROVIDER=openai

# -----------------------------------------------------------
# VECTOR DATABASE
# -----------------------------------------------------------
VECTOR_DB_BACKEND=pgvector  # pgvector | pinecone | qdrant | weaviate
VECTOR_DIMENSION=1536  # 1536 for text-embedding-3-large, 768 for BGE

# Pinecone (optional)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX=rag-enterprise

# Qdrant (optional)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=rag-documents

# Weaviate (optional)
WEAVIATE_URL=http://localhost:8090
WEAVIATE_API_KEY=your-weaviate-api-key

# -----------------------------------------------------------
# DOCUMENT PROCESSING
# -----------------------------------------------------------
MAX_FILE_SIZE_MB=100
ALLOWED_FILE_TYPES=pdf,docx,doc,txt,html,md,csv,xlsx,xls
ENABLE_OCR=true
OCR_ENGINE=tesseract  # tesseract | azure_di

# Azure Document Intelligence
AZURE_DI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DI_KEY=your-azure-di-key

# Chunking defaults
DEFAULT_CHUNK_SIZE=512
DEFAULT_CHUNK_OVERLAP=50
DEFAULT_CHUNKING_STRATEGY=recursive  # fixed | recursive | semantic | parent_child

# Virus scanning
ENABLE_VIRUS_SCAN=false  # Enable in production with ClamAV
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# -----------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_UPLOAD_PER_DAY=100

# -----------------------------------------------------------
# CORS
# -----------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true

# -----------------------------------------------------------
# MONITORING
# -----------------------------------------------------------
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
OTLP_ENDPOINT=http://localhost:4317
SENTRY_DSN=your-sentry-dsn

# -----------------------------------------------------------
# EMAIL / NOTIFICATIONS
# -----------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@your-org.com
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=Enterprise RAG <noreply@your-org.com>

# -----------------------------------------------------------
# FRONTEND (Next.js)
# -----------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=rag-enterprise
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=rag-frontend
NEXT_PUBLIC_APP_NAME=Enterprise RAG Assistant
NEXT_PUBLIC_ORG_NAME=Your Organization

# -----------------------------------------------------------
# SECURITY
# -----------------------------------------------------------
ENABLE_PII_MASKING=true
ENABLE_CONTENT_MODERATION=true
ENABLE_PROMPT_INJECTION_DEFENSE=true
MAX_CONTEXT_TOKENS=8000
MAX_OUTPUT_TOKENS=4000

# -----------------------------------------------------------
# COST TRACKING
# -----------------------------------------------------------
ENABLE_COST_TRACKING=true
MONTHLY_BUDGET_USD=500
ALERT_BUDGET_THRESHOLD_PERCENT=80
